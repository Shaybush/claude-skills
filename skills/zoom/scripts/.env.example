# Zoom Server-to-Server OAuth credentials — copy to .env (same folder) and fill in.
# .env is gitignored and the model never reads it.
# Create the app at https://marketplace.zoom.us/develop/create (choose
# "Server-to-Server OAuth"), add scopes, then click Activate. All three values
# come from the app's "App Credentials" tab. See SETUP.md.
ZOOM_ACCOUNT_ID=''
ZOOM_CLIENT_ID=''
ZOOM_CLIENT_SECRET=''
